# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION_STRING=Server=sqlserver,1433;Database=MinionDb;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=true
DB_SA_PASSWORD=CHANGE_ME_SA_PASSWORD

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_64

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://api.yourdomain.com

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_ENABLED=true
# Paste the entire service account JSON on a single line (escape quotes)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_ENABLED=true
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
