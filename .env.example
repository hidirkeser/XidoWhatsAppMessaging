# ── API Authentication ────────────────────────────────────────────────────────
# Minion ve diğer clientlar bu key'i X-Api-Key header'ında gönderir
ApiKey=CHANGE_ME_STRONG_RANDOM_KEY

# ── WhatsApp Provider Seçimi ──────────────────────────────────────────────────
# Değerler: AiSensy | Wati | Twilio
WhatsApp__Provider=AiSensy
WhatsApp__Enabled=true

# ── AiSensy ──────────────────────────────────────────────────────────────────
WhatsApp__AiSensy__ApiKey=your_aisensy_api_key
WhatsApp__AiSensy__CampaignName=your_campaign_name

# ── WATI ─────────────────────────────────────────────────────────────────────
WhatsApp__Wati__ApiEndpoint=https://live-mt-server.wati.io
WhatsApp__Wati__BearerToken=your_wati_bearer_token
WhatsApp__Wati__TemplateName=
WhatsApp__Wati__BroadcastName=xido_delegation

# ── Twilio ────────────────────────────────────────────────────────────────────
WhatsApp__Twilio__AccountSid=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WhatsApp__Twilio__AuthToken=your_twilio_auth_token
WhatsApp__Twilio__From=whatsapp:+46XXXXXXXXXX

# ── Database (SQLite — Railway volume'a bağlanır) ─────────────────────────────
ConnectionStrings__DefaultConnection=Data Source=/app/data/xido_whatsapp.db
