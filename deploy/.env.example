# ─────────────────────────────────────────────────────────────────────────────
# Minion — Production Environment Variables
# Copy this file to /opt/minion/.env on the Hetzner server
# NEVER commit the real .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# GitHub repository (owner/repo) — used to pull the Docker image from GHCR
GITHUB_REPO=YOUR_GITHUB_USERNAME/YOUR_REPO_NAME

# Domain name (without https://)
DOMAIN=api.minion.app

# Let's Encrypt email
CERTBOT_EMAIL=you@example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Strong password — min 8 chars, uppercase, lowercase, digit, special char
SA_PASSWORD=Minion@Prod2024!ChangeMe

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# ── BankID ────────────────────────────────────────────────────────────────────
# Test environment (default):
BANKID_BASE_URL=https://appapi2.test.bankid.com/rp/v6.0/
# Production (when you have the production cert from BankID):
# BANKID_BASE_URL=https://appapi2.bankid.com/rp/v6.0/

# Password for the BankID .pfx certificate file (in deploy/certs/bankid.pfx)
BANKID_CERT_PASSWORD=qwerty123

# ── Firebase (FCM Push Notifications) ────────────────────────────────────────
# Set to true and paste the service account JSON to enable real push notifications
FIREBASE_ENABLED=false
# Paste the full JSON content from Firebase Console → Service Accounts → Generate key
# Example: {"type":"service_account","project_id":"your-project",...}
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
EMAIL_FROM=noreply@minion.app
