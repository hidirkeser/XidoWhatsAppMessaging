# ─────────────────────────────────────────────────────────────────────────────
# Minion — Production Environment Variables
#
# Railway kullanımı:
#   Railway dashboard → Variables sekmesine bu değerleri gir.
#   DATABASE_URL Railway'in PostgreSQL servisi eklenince otomatik gelir.
#
# Lokal / self-hosted kullanım:
#   Bu dosyayı .env olarak kopyala ve gerçek değerleri gir.
# ─────────────────────────────────────────────────────────────────────────────

# ── Veritabanı ────────────────────────────────────────────────────────────────
# Railway → PostgreSQL servis ekleyince otomatik eklenir
# Lokal örnek: Host=localhost;Port=5432;Database=MinionDb;Username=postgres;Password=xxx
DATABASE_URL=Host=localhost;Port=5432;Database=MinionDb;Username=postgres;Password=ChangeMe

# ── JWT ───────────────────────────────────────────────────────────────────────
# Üretmek için: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# ── BankID ────────────────────────────────────────────────────────────────────
# Test (varsayılan):
BANKID_BASE_URL=https://appapi2.test.bankid.com/rp/v6.0/
# Production (gerçek sertifika aldıktan sonra):
# BANKID_BASE_URL=https://appapi2.bankid.com/rp/v6.0/

BANKID_CERT_PASSWORD=qwerty123

# ── Firebase (FCM Push) ───────────────────────────────────────────────────────
FIREBASE_ENABLED=false
# Firebase Console → Service Accounts → Generate key → JSON içeriğini buraya yapıştır
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
EMAIL_FROM=noreply@minion.app

# ── App URL ───────────────────────────────────────────────────────────────────
# Railway'de proje adın neyse otomatik oluşur: https://PROJE_ADI.up.railway.app
APP_BASE_URL=https://minion.up.railway.app
